<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <title>当日交易明细</title>
  <style>
    body { background: black; color: #00FF99; font-family: sans-serif; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { border: 1px solid #00FF99; padding: 8px; text-align: center; }
    .btn { padding: 4px 8px; cursor: pointer; }
  </style>
</head>
<body>
  <h2>📅 当日交易明细</h2>
  <table id="recordTable">
    <thead>
      <tr>
        <th>标的代码</th>
        <th>标的名称</th>
        <th>方向</th>
        <th>单价</th>
        <th>数量</th>
        <th>订单金额</th>
        <th>成交日期</th>
        <th>备注</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <script type="module">
    import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';
    const supabase = createClient(
      'https://zcosfwmtatuheqrytvad.supabase.co',
      'YOUR_PUBLIC_ANON_KEY'
    );

    const user = await supabase.auth.getUser();
    const today = new Date().toISOString().slice(0, 10); // yyyy-mm-dd

    const { data, error } = await supabase
      .from('records')
      .select('*')
      .eq('user_id', user.data.user?.id)
      .eq('trade_date', today);

    if (data) {
      const tbody = document.querySelector('#recordTable tbody');
      data.forEach(row => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${row.symbol}</td>
          <td>${row.name}</td>
          <td>${row.side}</td>
          <td>${row.price}</td>
          <td>${row.quantity}</td>
          <td>${row.amount}</td>
          <td>${row.trade_date}</td>
          <td>${row.note}</td>
          <td>
            <button class="btn" onclick="editRecord(${row.id})">编辑</button>
            <button class="btn" onclick="deleteRecord(${row.id})">删除</button>
          </td>
        `;
        tbody.appendChild(tr);
      });
    }
  </script>
</body>
</html>
